RESOURCE "/shares/searchWebLoad/RetroIndex/bin/UrlNormalizePatterns.tsv";            
RESOURCE "/shares/searchWebLoad/RetroIndex/bin/UrlNormalizeRegexPatterns.tsv";       
RESOURCE "/shares/searchWebLoad/RetroIndex/bin/DpimFormatting.cfg";
RESOURCE "/shares/searchWebLoad/RetroIndex/bin/full_CB.wsv";
REFERENCE "/shares/searchWebLoad/RetroIndex/bin/ManagedUrlNormalizer.dll";
RESOURCE "/shares/searchWebLoad/RetroIndex/bin/NativeUrlNormalizer.dll";

//Resource and Reference
REFERENCE "/shares/bingads.platform.prod.indexgen/Data/IG_runtime_resources/common/FrontEndUtil.dll";
