public static class RandomGenerator
{
    // ?? ThreadStatic ????????????? Random ????? C# ?????
    [ThreadStatic] 
    private static Random localRandom;

    private static Random GlobalRandom = new Random();

    public static int GetRandom()
    {
        if (localRandom == null)
        {
            // ??????????????????????????
            int seed;
            lock (GlobalRandom)
            {
                // ?? Next() ????? Random ???
                seed = GlobalRandom.Next(); 
            }
            localRandom = new Random(seed);
        }
        return localRandom.Next();
    }
}


public static int GetSegmentPriority(string segment)
{
    if (segment == "Strategic") {
        return 5;
    } else if (segment == "Enterprise") {
        return 4;
    } else if (segment == "Corporate") {
        return 3;
    } else if (segment == "Channel Partner") {
        return 2;
    } else if (segment == "SMB") {
        return 1;
    } else {
        return 0;
    }
}

public static class ImageUtils
{
    public static int[] GetSize(string base64string)
    {
        if (string.IsNullOrWhiteSpace(base64string))
            return new int[] { 0, 0 };

        try
        {
            // 移除可能的 "data:image/png;base64," 前缀
            var commaIndex = base64string.IndexOf(',');
            if (commaIndex > 0)
                base64string = base64string.Substring(commaIndex + 1);

        var bytes = Convert.FromBase64String(base64string);
            if (bytes.Length == 0)
                return new int[] { 0, 0 };

        using (var stream = new MemoryStream(bytes))
            using (var image = Image.FromStream(stream, useEmbeddedColorManagement: false, validateImageData: false))
            {
                return new int[] { image.Height, image.Width };
            }
        }
        catch (FormatException)
        {
            // Base64 格式无效
            return new int[] { 0, 0 };
        }
        catch (ArgumentException)
        {
            // 参数无效（不是合法图片）
            return new int[] { 0, 0 };
        }
        catch (Exception)
        {
            // 其他未知异常
            return new int[] { 0, 0 };
        }
    }
} 


using System;
using System.Collections.Generic;
using System.Linq;
using ScopeRuntime;

public class AggregateImageByAspectReducer : Reducer
{
    public override Schema Produces(string[] requestedColumns, string[] args, Schema input)
    {
        var schema = new Schema();
        
        // ????????? ImageUrl ? RatioType ?????
        foreach (var col in input.Columns)
        {
            if (col.Name != "ImageUrl" && col.Name != "RatioType")
            {
                schema.Add(col);
            }
        }
        
        // ??????????
        schema.Add(new ColumnInfo("WideImage1_w", typeof(string)));
        schema.Add(new ColumnInfo("WideImage1_h", typeof(string)));
        schema.Add(new ColumnInfo("WideImage2_w", typeof(string)));
        schema.Add(new ColumnInfo("WideImage2_h", typeof(string))); 
        schema.Add(new ColumnInfo("WideImage3_w", typeof(string))); 
        schema.Add(new ColumnInfo("WideImage3_h", typeof(string))); 
        schema.Add(new ColumnInfo("WideImage1", typeof(string)));
        schema.Add(new ColumnInfo("WideImage2", typeof(string)));
        schema.Add(new ColumnInfo("WideImage3", typeof(string)));
        schema.Add(new ColumnInfo("TallImage1", typeof(string)));
        schema.Add(new ColumnInfo("TallImage2", typeof(string)));
        schema.Add(new ColumnInfo("TallImage3", typeof(string)));
        //WideImage1_ad_type
        schema.Add(new ColumnInfo("WideImage1_ad_type", typeof(string)));
        schema.Add(new ColumnInfo("WideImage2_ad_type", typeof(string)));
        schema.Add(new ColumnInfo("WideImage3_ad_type", typeof(string)));
        schema.Add(new ColumnInfo("TallImage1_ad_type", typeof(string)));
        schema.Add(new ColumnInfo("TallImage2_ad_type", typeof(string)));
        schema.Add(new ColumnInfo("TallImage3_ad_type", typeof(string)));
        
        return schema;
    }
   
public override IEnumerable<Row> Reduce(RowSet input, Row outputRow, string[] args)
{
    outputRow.Reset();
    
    var wide = new List<string>();
    var tall = new List<string>();
    var wide_width = new List<string>(); 
    var wide_height = new List<string>();    
    var tall_width = new List<string>(); 
    var tall_height = new List<string>();  
    var wide_ad_type = new List<string>(); 
    var tall_ad_type = new List<string>(); 
    bool firstRead = true;
    
    // ???????????? WideImage1 ???
    int commonColumnsEnd = outputRow.Schema.IndexOf("WideImage1");
    
    foreach (Row row in input.Rows)
    {
        if (firstRead)
        {
            // ????????????
            for (int i = 0; i < commonColumnsEnd; i++)
            {
                string colName = outputRow.Schema[i].Name;
                // ?????????
                if (row.Schema.Contains(colName))
                {
                    row[colName].CopyTo(outputRow[i]);
                }
            }
            firstRead = false;
        }
        
        // ??URL
        string url = row["ImageUrl"].String;
        string ratioType = row["RatioType"].String;
       
        if (ratioType == "WideImages")
        {
            wide.Add(url);
            wide_width.Add(row["Width"].String);
            wide_height.Add(row["Height"].String);
            wide_ad_type.Add(row["Displayed_source_AdType"].String);
        }
        else if (ratioType == "TallImages")
        {
            tall.Add(url);
            tall_width.Add(row["Width"].String);
            tall_height.Add(row["Height"].String);
            tall_ad_type.Add(row["Displayed_source_AdType"].String);
        }
    }
    
    // ?????
    outputRow["WideImage1_w"].Set(wide_width.Count > 0 ? wide_width[0] : "");
    outputRow["WideImage1_h"].Set(wide_height.Count > 0 ? wide_height[0] : ""); 
    outputRow["WideImage2_w"].Set(wide_width.Count > 1 ? wide_width[1] : "");   
    outputRow["WideImage2_h"].Set(wide_height.Count > 1 ? wide_height[1] : ""); 
    outputRow["WideImage3_w"].Set(wide_width.Count > 2 ? wide_width[2] : "");       
    outputRow["WideImage3_h"].Set(wide_height.Count > 2 ? wide_height[2] : "");
    outputRow["WideImage1"].Set(wide.Count > 0 ? wide[0] : "");
    outputRow["WideImage2"].Set(wide.Count > 1 ? wide[1] : "");
    outputRow["WideImage3"].Set(wide.Count > 2 ? wide[2] : "");
    outputRow["TallImage1"].Set(tall.Count > 0 ? tall[0] : "");
    outputRow["TallImage2"].Set(tall.Count > 1 ? tall[1] : "");
    outputRow["TallImage3"].Set(tall.Count > 2 ? tall[2] : "");
   
    outputRow["WideImage1_ad_type"].Set(wide.Count > 0 && wide_ad_type.Count > 0 ? wide_ad_type[0] : "");
    outputRow["WideImage2_ad_type"].Set(wide.Count > 1 && wide_ad_type.Count > 0 ? wide_ad_type[0] : "");
    outputRow["WideImage3_ad_type"].Set(wide.Count > 2 && wide_ad_type.Count > 0 ? wide_ad_type[0] : "");
    outputRow["TallImage1_ad_type"].Set(tall.Count > 0 && tall_ad_type.Count > 0 ? tall_ad_type[0] : "");
    outputRow["TallImage2_ad_type"].Set(tall.Count > 1 && tall_ad_type.Count > 0 ? tall_ad_type[0] : "");
    outputRow["TallImage3_ad_type"].Set(tall.Count > 2 && tall_ad_type.Count > 0 ? tall_ad_type[0] : "");
    
    yield return outputRow;
}
}

public class GenerateImageExtensionItemData : Reducer
{

    public override Schema Produces(string[] columns, string[] args, Schema input)
    {
        return new Schema("AdExtensionItemId:long,AdExtensionId:long, AssetId:string, MediaURL:string, DestintationUrl:string,OriginalMediaHeight:string, OriginalMediaWidth:string, AltText:string, AssetId2:string, AssetId3:string, AssetId4:string, AssetId5:string");
    }

    public override IEnumerable<Row> Reduce(RowSet input, Row output, string[] args)
    {
        long AdExtensionItemId = 0;
        long AdExtensionId = 0;  
        string AssetId = string.Empty;
        string MediaURL = string.Empty;
        string DestintationUrl = string.Empty;        
        string OriginalMediaHeight = string.Empty;
        string OriginalMediaWidth = string.Empty;
        string AltText = string.Empty;
        string AssetId2 = string.Empty;
        string AssetId3 = string.Empty;
        string AssetId4 = string.Empty;
        string AssetId5 = string.Empty;
        int count = 0;
        
        foreach (Row row in input.Rows)
        {
            if (++count == 1)
            {
    
                AdExtensionItemId = row["AdExtensionItemId"].Long;
                AdExtensionId = row["AdExtensionId"].Long;
            }
            
            var propertyId = row["AdExtensionPropertyId"].Integer;
            var propertValue = row["AdExtensionPropertyValue"].String;

            if (propertyId == 48)
                AssetId = propertValue;
            else if (propertyId == 49)
                MediaURL = propertValue;
            else if (propertyId == 50)
                DestintationUrl = propertValue;
            else if (propertyId == 51)
                OriginalMediaHeight = propertValue;
            else if (propertyId == 52)
                OriginalMediaWidth = propertValue;
            else if (propertyId == 53)
                AltText = propertValue;
            else if (propertyId == 113)
                AssetId2 = propertValue;
            else if (propertyId == 114)
                AssetId3 = propertValue;
            else if (propertyId == 115)
                AssetId4 = propertValue;
            else if (propertyId == 297)
                AssetId5 = propertValue;
        }
        
        
        output["AdExtensionItemId"].Set(AdExtensionItemId);
        output["AdExtensionId"].Set(AdExtensionId);
        output["AssetId"].Set(AssetId);
        output["MediaURL"].Set(MediaURL);
        output["DestintationUrl"].Set(DestintationUrl);
        output["OriginalMediaHeight"].Set(OriginalMediaHeight);
        output["OriginalMediaWidth"].Set(OriginalMediaWidth);
        output["AltText"].Set(AltText);
        output["AssetId2"].Set(AssetId2);
        output["AssetId3"].Set(AssetId3);
        output["AssetId4"].Set(AssetId4);
        output["AssetId5"].Set(AssetId5);
        yield return output;
    }
}
using Microsoft.SCOPE.Types;
using System;
using System.Collections.Generic;
using System.IO;
using System.Text;
using ScopeRuntime;
using Newtonsoft.Json;

public class AdExtensionItemProperty
{
    public Dictionary<int, string> p { get; set; }
}

public class AdExtensionItemPropertyParser
{

    /// AdExtensionData structure
    public struct AdExtensionData
    {
        public int AdExtensionPropertyId;
        public string AdExtensionPropertyValue;
     }

    /// Deserialize
    public static readonly JsonSerializerSettings JsonSerializerSettings = new JsonSerializerSettings
    {
        TypeNameHandling = TypeNameHandling.Auto
    };

    public static T Deserialize<T>(string jsonString)
    {
        if (string.IsNullOrWhiteSpace(jsonString))
        {
            throw new ArgumentException("Invalid Argument : Parameter compressedString is either Null or Empty");
        }
        var obj = JsonConvert.DeserializeObject<T>(jsonString, JsonSerializerSettings);
        return obj;
    }

    ///  parse the property string to list of AdExtensionData
    public static List<AdExtensionData> PropertyToData(string property_string)
    {
        var resultList = new List<AdExtensionData>();
        try
        {
            var property_dict = Deserialize<AdExtensionItemProperty>(property_string);
            foreach (KeyValuePair<int, string> entry in property_dict.p)
            {
                var elem = new AdExtensionData
                {
                    AdExtensionPropertyId = (int)entry.Key,
                    AdExtensionPropertyValue = entry.Value,
                };
                resultList.Add(elem);
            }
        } 
        catch (Exception) 
        {
            throw new ArgumentException(string.Format(@"Invalid json string : Error parsing Property in AdExtensionItem: {0}.", @property_string));
        }
        return resultList;
    }
}

#ENDCS