//Read ImgAssets
Ads_SnapShot =
    SELECT AccountId,
           CampaignId,
           OrderId,
		   AdId,
		   DestinationURL,
		   FinalURL,
           Domain
    FROM
    (
        VIEW @UnifiedLayerDemandView
        PARAMS
        (
            ViewName = "Ads",
            LogDate = @RunDate
        )
    );

Ads_SnapShot =
    SELECT DISTINCT *,
                    IF(string.IsNullOrEmpty(FinalURL), DestinationURL, FinalURL) AS FinalUrl
    FROM Ads_SnapShot
    HAVING FinalUrl.Length > 2;

Ads_SnapShot =
    SELECT *.Except(FinalUrl),
           IF(FinalUrl.ToLower().StartsWith("http"), FinalUrl, "http://"+FinalUrl) AS FinalUrl
    FROM Ads_SnapShot;



AdUrl = SELECT AdId,
            FIRST(FinalUrl) AS FinalUrl
        FROM Ads_SnapShot;
OrderUrl = 
        SELECT *,
               ROW_NUMBER() OVER(PARTITION BY OrderId) AS Rid
        FROM Ads_SnapShot
        HAVING Rid == 1;

CampaignUrl = 
        SELECT *,
               ROW_NUMBER() OVER(PARTITION BY CampaignId) AS Rid
        FROM Ads_SnapShot
        HAVING Rid == 1;

AccountCampgin = 
    SELECT DISTINCT AccountId,
                CampaignId
    FROM Ads_SnapShot;



//ImgExtension
AdExtensionAccountView =  
            SELECT AccountId,  
                   AdExtensionId  
            FROM  
            (  
                VIEW @C2CMasterView  
                PARAMS  
                (  
                      ViewName = "AdExtensionAccount_Raw",  
                      ViewType=1,                
                      RequestEndDateUtc= @RunDate,  
                    RequestEndHourUtc = 23          
                )  
            )
    WHERE LifeCycleStatusId != 110;
AdExtensionAccountView = 
    SELECT A.*,
    B.CampaignId
    FROM AdExtensionAccountView AS A
    INNER JOIN AccountCampgin AS B
    ON A.AccountId == B.AccountId;
 
AdExtensionCampaignView =  
            SELECT AccountID AS AccountId,
                   (long) CampaignId AS CampaignId,  
                   AdExtensionId  
            FROM  
            (  
                VIEW @C2CMasterView  
                PARAMS  
                (  
                      ViewName = "AdExtensionCampaign_Raw",  
                      ViewType=1,                
                      RequestEndDateUtc= @RunDate,  
                    RequestEndHourUtc = 23          
                )  
            )
            WHERE LifeCycleStatusId != 110;  

AdExtensionCampaignView = 
SELECT AccountId, CampaignId, AdExtensionId  FROM AdExtensionCampaignView
UNION ALL 
SELECT AccountId, CampaignId, AdExtensionId  FROM AdExtensionAccountView;

AdExtensionCampaignView = 
    SELECT A.*,
    B.FinalUrl??"" AS FinalUrl,
    B.AdId??0 AS AdId
    FROM AdExtensionCampaignView AS A 
    LEFT OUTER JOIN CampaignUrl AS B 
    ON A.CampaignId == B.CampaignId;

                               
AdExtensionOrderView =  
            SELECT AccountID AS AccountId,
                    OrderId,
                   CampaignId,
                   AdExtensionId  
            FROM  
            (  
                VIEW @C2CMasterView  
                PARAMS  
                (  
                      ViewName = "AdExtensionOrder_Raw",  
                      ViewType=1,                
                      RequestEndDateUtc= @RunDate,  
                    RequestEndHourUtc = 23          
                )  
            )
            WHERE LifeCycleStatusId != 110;

AdExtensionOrderView = 
    SELECT A.*,
    B.FinalUrl??"" AS FinalUrl,
    B.AdId??0 AS AdId
    FROM AdExtensionOrderView AS A 
    LEFT OUTER JOIN OrderUrl AS B 
    ON A.OrderId == B.OrderId;
AdExtension = 
    SELECT AccountId,
            CampaignId,
            AdExtensionId,
            FinalUrl,
           AdId
    FROM AdExtensionCampaignView
    UNION ALL
    SELECT  AccountId,
            CampaignId,
            AdExtensionId,
            FinalUrl,
            AdId
    FROM AdExtensionOrderView;

AdExtension = 
        SELECT 
            *.Except(AdExtensionId),
            AdExtensionId.ToString() AS AdExtensionId,
            ROW_NUMBER() OVER(PARTITION BY AccountId, CampaignId, AdExtensionId) AS Rid 
        FROM AdExtension
        HAVING Rid == 1;

//get adextensionId, assetId Mapping: process logic in aether pipeline: aether://experiments/034836e1-3849-4205-84cd-1d1c154a0593. Use the dumped result from latest exp

FullExtensionItemAssets = 
        SELECT  AdExtensionId,
                long.Parse(AssetId) AS AssetId
                FROM 
                (
                   SSTREAM "/shares/Bingads.algo.prod.IntentMatching/Data/aether/_7/rauser3/794775e9-5faf-47f2-a24c-f91164aa66bb@@@Full_set_ImageExtension_MS@@@7b1836f9@@@3-24-2026_12-39-00_PM/FullSetImageExtensionMS/FullSetImageExtensionMS_89b93094-5118-429c-b4a2-39cbdba5d0fb.ss"
                 );

FullExtensionItemAssets = 
        SELECT AdExtensionId,
        FIRST(AssetId) AS AssetId
        FROM FullExtensionItemAssets;



AdExtension =  
       SELECT A.*,
              B.AssetId
        FROM AdExtension AS A 
        INNER JOIN FullExtensionItemAssets AS B
        ON B.AdExtensionId == A.AdExtensionId; 

OUTPUT AdExtension TO SSTREAM @ImageExtension
WITH STREAMEXPIRY @StreamExpiry;





