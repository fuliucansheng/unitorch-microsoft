#DECLARE ResourceFolder string = @"/shares/bingads.algo.adinsights/prod/Users/xiaoyukou/resource";
#DECLARE LanguageMap string = string.Format("{0}/LanguageMap.ss", @ResourceFolder);


// Input Streams
#DECLARE AccSegRoot string = "/shares/bingads.algo.prod.adinsights/data/shared_data/DemandResources/AccountSegment/";
#DECLARE AccSegPath string = string.Format("{0}/{1:yyyy/MM}/AccountSegment_{1:yyyy-MM-dd}.ss", @AccSegRoot, @GeneratedEndDate);
#DECLARE C2CMasterView string = "/shares/adCenter.BICore.upload/prod/C2C/Views/MasterView/C2CMasterView.view"; 

#DECLARE UcmTacticInfoFile string = "/shares/bingads.algo.prod.adinsights/data/prod/pipelines/Optimization/UCM/Data/UcmTacticInfo.csv";
#DECLARE CDLFolder string = "/shares/bingads.algo.prod.adinsights/data/shared_data/AdvertiserEngagement/Metallica/prod/CommonDataFeed/";
#DECLARE AccountVertical string = @CDLFolder + "/Modules/AccountVertical.view"; // Account vertical
#DECLARE UnifiedLayerDemandView string = @"/shares/bingAds.BI.OI/AdsOI/DemandMetrics/Views/UnifiedLayerDemand.view"; 

#DECLARE PmaxAsset string = string.Format("{0}/PrepareData_PmaxAsset_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE MMAAsset string = string.Format("{0}/PrepareData_MMAAsset_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE ImageExtension string = string.Format("{0}/PrepareData_ImgExtension_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);
#DECLARE PerfData string = string.Format("{0}/PrepareData_CampaignPerf_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);


// Output Streams
#DECLARE Stat string = string.Format("{0}/PrepareData_{1:yyyy-MM-dd}_Stat.ss", @OutputFolder, @RunDate);
#DECLARE ImgAssetsData string = string.Format("{0}/PrepareData_AllVertical_{1:yyyy-MM-dd}.ss", @OutputFolder, @RunDate);

//Read ImgAssets
//Pmax:
AssetGroupAsset = SSTREAM @PmaxAsset;

//MMA:
AdAssets = SSTREAM @MMAAsset;

//ImgExtension
AdExtension = SSTREAM @ImageExtension;

//All assets
AllAssets = 
    SELECT AccountId,
           CampaignId,
           AssetGroupId AS AdId,
           AssetId,
           FinalUrl,
           AssetAssociationTypeId,
           "Pmax" AS Tag
    FROM AssetGroupAsset
    UNION ALL
    SELECT AccountId,
           CampaignId,
           AdId,
           (long) AssetId AS AssetId,
           FinalUrl,
           AssetAssociationTypeId,
           "Other" AS Tag
    FROM AdAssets
    UNION ALL
    SELECT AccountId,
           CampaignId,
           AdId,
           AssetId,
           FinalUrl,
           (short) 1 AS AssetAssociationTypeId,
           "ImgExtension" AS Tag
    FROM AdExtension;    

AllAssets  =
    SELECT *,
            ROW_NUMBER() OVER(PARTITION BY CampaignId, AdId, AssetId) AS Rid
    FROM AllAssets
    HAVING Rid == 1;


AllAssets = 
    SELECT *,
           IF(AssetAssociationTypeId IN (11, 32), "Headline", IF(AssetAssociationTypeId == 33, "LongHeadline", IF(AssetAssociationTypeId IN (12, 34), "Description", IF(AssetAssociationTypeId == 63, "BusinessName", IF(AssetAssociationTypeId == 1, "LandscapeImage", IF(AssetAssociationTypeId == 2, "SquareImage", IF(AssetAssociationTypeId == 3 OR AssetAssociationTypeId == 4, "Logo", "OtherSizeImage"))))))) AS AssetType
    FROM AllAssets
    HAVING AssetType NOT IN ("Logo","BusinessName");

Stat = SELECT "" AS Tag,
              "1.0 RawAssetsWithVarious Types" AS Name,
              COUNT(DISTINCT AccountId) AS Accounts,
              COUNT(DISTINCT CampaignId) AS Campaigns,
              COUNT(DISTINCT AdId) AS Ads,
              COUNT(DISTINCT AssetId) AS Assets,
              COUNT(DISTINCT FinalUrl) AS Urls,
              COUNT() AS Rows
        FROM AllAssets;

//Get CampaignPerf
Campaigns = SSTREAM @PerfData;
/*
Campaigns = SELECT * FROM Campaigns
            WHERE Vertical_L1 NOT IN ("Health & Wellness", "Adult & Gambling", "Financial Services & Insurance") 
            AND Vertical_L2 NOT IN ("Drug/Pharma (Retail)");
*/

Campaigns  =
    SELECT *,
            ROW_NUMBER() OVER(PARTITION BY CampaignId) AS Rid
    FROM Campaigns
    HAVING Rid == 1;
//Get Content
AllAssets = 
    SELECT A.*,
            B.RevenueUSD AS CampaignSpend,
            B.Impressions AS CampaignImpr,
            B.Clicks AS CampaignClick,
            B.Segment,
            B.Vertical_L1,
            B.Vertical_L2,
            B.Vertical_L3,
            B.Vertical_L4
    FROM AllAssets AS A
    INNER JOIN Campaigns AS B
    ON A.CampaignId == B.CampaignId;
Stat = 
    SELECT * FROM Stat
    UNION ALL
    SELECT    "" AS  Tag,
              "2.0 RawAssets with valid campaign/account setting" AS Name,
              COUNT(DISTINCT AccountId) AS Accounts,
              COUNT(DISTINCT CampaignId) AS Campaigns,
              COUNT(DISTINCT AdId) AS Ads,
              COUNT(DISTINCT AssetId) AS Assets,
              COUNT(DISTINCT FinalUrl) AS Urls,
              COUNT() AS Rows
     FROM AllAssets;

ImgAssets = SELECT * FROM AllAssets
    WHERE AssetType NOT IN ("Headline","LongHeadline","Description");
TextAssets = SELECT DISTINCT AdId, AssetId FROM AllAssets
    WHERE AssetType IN ("Headline","LongHeadline","Description");
Stat = 
    SELECT * FROM Stat
    UNION ALL
    SELECT Tag,
              "2.1 RawAssets with valid campaign/account setting - Imgs" AS Name,
              COUNT(DISTINCT AccountId) AS Accounts,
              COUNT(DISTINCT CampaignId) AS Campaigns,
              COUNT(DISTINCT AdId) AS Ads,
              COUNT(DISTINCT AssetId) AS Assets,
              COUNT(DISTINCT FinalUrl) AS Urls,
              COUNT() AS Rows
     FROM ImgAssets;


//Get Content
// text asset detail
TextAssetsDetails =
    SELECT AssetId,
        AssetText	      
    FROM
    (
        VIEW @C2CMasterView
        PARAMS
        (
            ViewName = "TextAsset_Raw",
            ViewType = @SnapshotViewType,
            RequestEndDateUtc = @RunDate,
            RequestEndHourUtc = 23
        )
    );
TextAssetsDetails = SELECT AssetId,
                FIRST(AssetText) AS AssetText
                FROM TextAssetsDetails;

TextAssets = 
    SELECT A.*,
    B.AssetText
    FROM TextAssets AS A
    INNER JOIN TextAssetsDetails AS B 
    ON A.AssetId == B.AssetId;
TextAssets = 
    SELECT AdId,
        string.Join("[SEP]", ARRAY_AGG(AssetText)) AS Text
    FROM TextAssets;

// image asset detail
ImgAssetsDetails =
    SELECT AssetId, 
        Url AS ImgUrl, 
        (int) OriginalMediaWidth AS OriginalMediaWidth, 
        (int) OriginalMediaHeight AS OriginalMediaHeight
    FROM
    (
        VIEW @C2CMasterView
        PARAMS
        (
            ViewName = "Asset_Raw",
            ViewType = @SnapshotViewType,
            RequestEndDateUtc = @RunDate,
            RequestEndHourUtc = 23,
            ViewMode = "PROD",
            DataMode = "PROD"
        )
    )
    WHERE OriginalMediaWidth != null AND OriginalMediaHeight != null;
ImgAssetsDetails = SELECT AssetId,
                FIRST(ImgUrl) AS ImgUrl,
                FIRST(OriginalMediaWidth) AS OriginalMediaWidth,
                FIRST(OriginalMediaHeight) AS OriginalMediaHeight
                FROM ImgAssetsDetails;

ImgAssets = 
    SELECT A.*,
            B.ImgUrl,
            B.OriginalMediaWidth,
            B.OriginalMediaHeight
            FROM ImgAssets AS A
            INNER JOIN ImgAssetsDetails AS B
            ON A.AssetId == B.AssetId;

Stat = 
    SELECT * FROM Stat
    UNION ALL
    SELECT Tag,
              "3.0 Imgs with Metadata" AS Name,
              COUNT(DISTINCT AccountId) AS Accounts,
              COUNT(DISTINCT CampaignId) AS Campaigns,
              COUNT(DISTINCT AdId) AS Ads,
              COUNT(DISTINCT AssetId) AS Assets,
              COUNT(DISTINCT FinalUrl) AS Urls,
              COUNT() AS Rows
     FROM ImgAssets;

ImgAssets = 
    SELECT A.*,
            B.Text??"" AS Text
    FROM ImgAssets AS A
    LEFT OUTER JOIN TextAssets AS B
    ON A.AdId == B.AdId;

Stat = 
    SELECT * FROM Stat
    UNION ALL
    SELECT Tag,
              "4.0 Imgs with texts" AS Name,
              COUNT(DISTINCT AccountId) AS Accounts,
              COUNT(DISTINCT CampaignId) AS Campaigns,
              COUNT(DISTINCT AdId) AS Ads,
              COUNT(DISTINCT AssetId) AS Assets,
              COUNT(DISTINCT FinalUrl) AS Urls,
              COUNT() AS Rows
     FROM ImgAssets
    UNION ALL
    SELECT Tag,
              "4.1 Imgs with texts - not null" AS Name,
              COUNT(DISTINCT AccountId) AS Accounts,
              COUNT(DISTINCT CampaignId) AS Campaigns,
              COUNT(DISTINCT AdId) AS Ads,
              COUNT(DISTINCT AssetId) AS Assets,
              COUNT(DISTINCT FinalUrl) AS Urls,
              COUNT() AS Rows
     FROM ImgAssets
     WHERE Text != "";






OUTPUT ImgAssets TO SSTREAM @ImgAssetsData
CLUSTERED BY AccountId, CampaignId, Tag
WITH STREAMEXPIRY @StreamExpiry;

OUTPUT Stat TO SSTREAM @Stat
CLUSTERED BY Tag, Name
SORTED BY Name
WITH STREAMEXPIRY @StreamExpiry;




